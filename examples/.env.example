# Provider URLs
export OLLAMA_BASE_URL=http://127.0.0.1:11434   # (default http://127.0.0.1:11434)

# API keys (REQUIRED for the provider you use)
export OPENROUTER_API_KEY=     # required if provider=openrouter
export OPENCODE_ZEN_API_KEY=   # required if provider=opencode_zen
export OPENAI_API_KEY=         # required if provider=openai

# Optional provider overrides
export OPENCODE_ZEN_BASE_URL=  # (default https://opencode.ai/zen)
export OPENAI_ORG_ID=          # OpenAI organization ID
export OPENAI_BASE_URL=        # endpoint override (Azure/compatible)
export OPENAI_TIMEOUT=120      # HTTP client timeout in seconds (default 120)

# Global overrides
export SHMORBY_PROVIDER=       # overrides provider from config file
export SHMORBY_MODEL=          # overrides model from config file
export SHMORBY_TOOLS_TIMEOUT=120  # tool execution timeout in seconds (default 120)
export SHMORBY_TOOL_OUTPUT_MAX_LINES=0   # 0 = unlimited line-level truncation
export SHMORBY_TOOL_OUTPUT_MAX_BYTES=0   # 0 = unlimited byte-level truncation (was 65536)
